end)

-- Logika Notify (Disable Anim & You Got)
BtnNotify.MouseButton1Click:Connect(function()
    isNotify = not isNotify
    BtnNotify.BackgroundTransparency = isNotify and 0 or 0.4
    if isNotify then
        RunService:BindToRenderStep("Easter_Optimizer", Enum.RenderPriority.Camera.Value + 1, function()
            local char = Player.Character
            if char and char:FindFirstChild("Humanoid") then
                for _, v in pairs(char.Humanoid:GetPlayingAnimationTracks()) do v:Stop() end
            end
            for _, gui in pairs(PlayerGui:GetChildren()) do
                if gui:IsA("ScreenGui") and gui.Name ~= "EasterIslandUI" then
                    for _, v in pairs(gui:GetDescendants()) do
                        if v:IsA("TextLabel") or v:IsA("ImageLabel") then
                            local txt = v:IsA("TextLabel") and v.Text:lower() or ""
                            if txt:find("you got:") then
                                v.Visible = false
                                if v.Parent:IsA("Frame") then v.Parent.Visible = false end
                            end
                        end
                    end
                end
            end
        end)
    else
        RunService:UnbindFromRenderStep("Easter_Optimizer")
    end
end)

