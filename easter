-- Logika Weather (UPDATED REMOTES & TIME)
BtnWeather.MouseButton1Click:Connect(function()
    isWeather = not isWeather
    BtnWeather.BackgroundTransparency = isWeather and 0 or 0.4
    if isWeather then
        task.spawn(function()
            local RF_Weather = Net:WaitForChild("RF/ebd816eb3d35df090379f18e5badd15cc5b129ed0fa83ffafdbac71858d507f0")
            while isWeather do
                pcall(function() 
                    local args = { [1] = "Cloudy" }
                    RF_Weather:InvokeServer(unpack(args)) 
                end)
                task.wait(1)
                
                if not isWeather then break end
                pcall(function() 
                    local args = { [1] = "Wind" }
                    RF_Weather:InvokeServer(unpack(args)) 
                end)
                task.wait(1)
                
                if not isWeather then break end
                pcall(function() 
                    local args = { [1] = "Storm" }
                    RF_Weather:InvokeServer(unpack(args)) 
                end)
                
                -- Jeda 1 Menit (60 Detik)
                for i = 60, 1, -1 do
                    if not isWeather then break end
                    task.wait(1)
                end
            end
        end)
    end
end)

