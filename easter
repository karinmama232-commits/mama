-- --- 1. OPTIMIZER: DISABLE ANIM & NOTIFY --- --
RunService:BindToRenderStep("pociXkarin_Optimizer", Enum.RenderPriority.Camera.Value + 1, function()
    if isOptiEnabled then
        -- 1. Disable Animation
        local char = Player.Character
        if char and char:FindFirstChild("Humanoid") then
            for _, v in pairs(char.Humanoid:GetPlayingAnimationTracks()) do 
                v:Stop() 
            end
        end

        -- 2. Disable Notification ("you got:")
        for _, gui in pairs(PlayerGui:GetChildren()) do
            if gui:IsA("ScreenGui") and gui.Name ~= "pociXkarinUI" then
                for _, v in pairs(gui:GetDescendants()) do
                    if v:IsA("TextLabel") or v:IsA("ImageLabel") then
                        local txt = v:IsA("TextLabel") and v.Text:lower() or ""
                        if txt:find("you got:") then
                            v.Visible = false
                            if v.Parent:IsA("Frame") then 
                                v.Parent.Visible = false 
                            end
                        end
                    end
                end
            end
        end
    end
end)


