-- Logika Egg (UPDATED REMOTES)
local moveTick = 3550 
task.spawn(function()
    local targetCFrame = CFrame.new(1187.18164, 10.8309031, 2592.33643, 0.59283185, 1.60291957e-08, 0.805326283, -5.46121512e-08, 1, 2.02981418e-08, -0.805326283, -5.60139846e-08, 0.59283185)
    local RF_Egg1 = Net:WaitForChild("RF/fb508dc54cae55e3c5777b46de06adebc23004890c271a966e54c29ad0d2a282")
    local RF_Egg2 = Net:WaitForChild("RF/a457e6def5b5aefc3a5f139f5fc7d9ad2c3a1bae763131bb590f14d865ab2ce6")

    while true do
        task.wait(1)
        if isEgg then
            moveTick = moveTick + 1
            if moveTick >= 3610 then 
                local char = Player.Character
                local hrp = char and char:FindFirstChild("HumanoidRootPart")
                
                if hrp then
                    local savedPos = hrp.CFrame
                    task.wait(2)
                    hrp.CFrame = targetCFrame
                    task.wait(1)
                    
                    for i = 1, 6 do
                        pcall(function()
                            RF_Egg1:InvokeServer()
                            RF_Egg2:InvokeServer()
                        end)
                        task.wait(2)
                    end
                    
                    task.wait(2)
                    hrp.CFrame = savedPos
                end
                moveTick = 0 
            end
        else
            moveTick = 3550 
        end
    end
end)

BtnEgg.MouseButton1Click:Connect(function()
