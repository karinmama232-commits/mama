-- --- 4. JALUR AUTO MOVE & EGG (Dengan Sistem Tick) --- --
local moveTick = 3550 
task.spawn(function()
    while true do
        task.wait(1) 
        if isAutoMove then
            moveTick = moveTick + 1
            if moveTick >= 3610 then 
                local char = game.Players.LocalPlayer.Character
                local hrp = char and char:FindFirstChild("HumanoidRootPart")

                if hrp then
                    local savedPos = hrp.CFrame
                    task.wait(2)
                    hrp.CFrame = targetCFrame
                    task.wait(1)

                    for i = 1, 6 do
                        pcall(function()
                            RF_Egg1:InvokeServer()
                            RF_Egg2:InvokeServer()
                        end)
                        task.wait(2)
                    end

                    task.wait(2)
                    hrp.CFrame = savedPos
                end
                moveTick = 0 
            end
        else
            moveTick = 3550 
        end
    end
end)


